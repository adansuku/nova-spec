# ═══════════════════════════════════════════════════════════════════
#  nova-spec — .gitignore
#
#  This repo is the SOURCE of nova-spec, but we also dogfood it here:
#  running `npx nova-spec init` in this directory creates artifacts
#  that aren't source. This file separates what's source from what's
#  generated, so the dogfooding doesn't pollute git status.
#
#  Sections:
#    1. Dependencies
#    2. OS / editor cruft
#    3. BMad workspace (brainstorming outputs)
#    4. Personal / local-only files
#    5. Dogfooding artifacts (when nova-spec runs against itself)
#
#  NOT here: the gitignore block the installer adds to CONSUMER repos
#  lives in lib/installer.js → ensureGitignore(). Don't conflate them.
# ═══════════════════════════════════════════════════════════════════


# ─── 1. Dependencies & build artifacts ─────────────────────────────
# Installed via `npm install`. Reproducible from package.json.
node_modules/

# VitePress build output for the docs site (deployed via GitHub Action)
docs/.vitepress/dist/
docs/.vitepress/cache/


# ─── 2. OS / editor cruft ──────────────────────────────────────────
.DS_Store
*.swp
*.swo


# ─── 3. BMad workspace ─────────────────────────────────────────────
# Brainstorming sessions and planning outputs generated by the bmad-*
# skills. Not part of the framework's source.
_bmad/
_bmad-output/


# ─── 4. Personal / local-only ──────────────────────────────────────
# Only in a dev's working tree; never commit them.
# - .env  → API tokens (JIRA_API_TOKEN, etc.)
# - notes.md → personal scratch pad
.env
notes.md


# ─── 5. Dogfooding artifacts ───────────────────────────────────────
# `npx nova-spec init` (run inside THIS repo for testing) plus
# various AI-runtime caches create the directories below. They are
# runtime state, not source — each developer has their own.
#
# Note: novaspec/{commands,skills,agents,templates,guardrails}/ IS
# source and stays tracked. Only the generated bits are ignored.

# Claude Code's symlinks + settings
.claude/

# Same for OpenCode
.opencode/

# Skill mirror used by some agent runtimes
.agents/

# Architectural memory: only meaningful in CONSUMER repos.
# In the source repo, whatever's here is test data.
context/

# Personal Jira / forge config (per dev)
novaspec/config.yml

# Sync state, auto-regenerated
novaspec/.nova-manifest.json
